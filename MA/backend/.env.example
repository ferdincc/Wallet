# Kopyalayın: copy .env.example .env  —  gerçek anahtarları asla repoya eklemeyin.

# Opsiyonel: sunucunun genel Binance erişimi (simülasyon kullanıcı anahtarları DB'de saklanır)
BINANCE_API_KEY=
# Gizli anahtar (alternatif isim: BINANCE_SECRET_KEY)
BINANCE_API_SECRET=

# ccxt HTTP zaman aşımı (milisaniye); varsayılan 15000 (yavaş ağ / Binance için)
# EXCHANGE_CCXT_TIMEOUT_MS=15000
# İmzalı uçlar (bakiye/emir/pozisyon), varsayılan 15000
# EXCHANGE_PRIVATE_TIMEOUT_MS=15000
# Binance recvWindow (timestamp hataları için), varsayılan 60000
# BINANCE_RECV_WINDOW_MS=60000

DATABASE_URL=sqlite:///./okyiss.db

