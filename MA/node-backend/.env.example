# HTTP port (Vite dev proxy ile uyumlu; 3010 doluysa örn. PORT=3020 yapın ve frontend/vite.config NODE_BACKEND_PORT ile eşleştirin)

PORT=3010



# Alchemy — cüzdan analizi (/api/wallet) için zorunlu

# https://dashboard.alchemy.com/ — ALCHEMY_API_KEY ile tüm desteklenen ağlar

ALCHEMY_API_KEY=



# Etherscan / explorer anahtarları (cüzdan analizi artık kullanmıyor; diğer özellikler için tutulabilir)

ETHERSCAN_API_KEY=

BSCSCAN_API_KEY=

POLYGONSCAN_API_KEY=

ARBISCAN_API_KEY=



# İsteğe bağlı: tüm zincirler için varsayılan (genelde boş bırakın)

# DEFAULT_SCAN_API_KEY=demo



# Prisma / DB (mevcut)

# DATABASE_URL=file:./prisma/dev.db

